{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "resolveJsonModule": true,

    "esModuleInterop": true,
    "paths": {
      "@/*": ["*"],
      "@src/*": ["src/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "**/*.js",
    "**/*.jsx",
    "**/*.json",
    ".expo/types/**/*.ts",
    "expo-env.d.ts"
  ]
}